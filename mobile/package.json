{
  "name": "ds-partner-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DS Partner Platform — мобильное приложение (Capacitor 6 + Vue 3 + Vuetify 3)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --port 5174",
    "type-check": "vue-tsc --noEmit",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "cap:run:android": "npm run cap:sync && cap run android",
    "cap:run:ios": "npm run cap:sync && cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@mdi/font": "^7.4.47",
    "axios": "^1.7.9",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vuetify": "^3.7.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "sass-embedded": "^1.83.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-vuetify": "^2.0.4",
    "vue-tsc": "^2.2.0"
  }
}
