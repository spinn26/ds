# Шаблон для подписи release APK / AAB.
# Скопируй в keystore.properties (этот файл .gitignore-ит), заполни своими значениями.
#
# 1. Создай keystore командой (в папке mobile/android/app):
#    keytool -genkey -v -keystore ds-release.keystore -alias ds -keyalg RSA -keysize 2048 -validity 10000
#
# 2. После создания файла .keystore — заполни параметры здесь.
# 3. НИКОГДА не коммить keystore.properties и .keystore — потеряешь подпись = потеряешь приложение
#    (Google Play не даст обновлять с другим keystore).

storeFile=ds-release.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=ds
keyPassword=YOUR_KEY_PASSWORD
