APP_NAME="DS Consulting"
APP_ENV=local
APP_KEY=
# Enable only for local/dev. Never ship APP_DEBUG=true to production — it leaks stack traces.
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# На проде используй `daily` (rotation 14 дней, см. config/logging.php).
# `single` подходит только для локалки.
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# На проде ОБЯЗАТЕЛЬНО `warning` или `error`. `debug` пишет каждый SQL —
# логи раздуют диск за день и в них утекают параметры запросов.
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=newds
DB_USERNAME=newds
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Socket.IO real-time server (see socket-server/)
SOCKET_HOST=127.0.0.1
SOCKET_PORT=3001
SOCKET_API_PORT=3002
SOCKET_ORIGINS="http://localhost:8000,https://dev.dsconsult.ru"
# Shared secret between Laravel and socket-server for HTTP emit auth.
# Generate with: openssl rand -hex 32
SOCKET_EMIT_SECRET=
# Laravel URL that socket-server calls to validate Sanctum tokens
LARAVEL_API_URL=http://127.0.0.1:8000

# Google Sheets — источник данных для импорта транзакций.
# ID таблицы из URL (часть между /d/ и /edit).
# API key: console.cloud.google.com → Credentials → API key.
#   Обязательно включи Google Sheets API в библиотеке и ограничь
#   ключ по HTTP-referrer / IP в проде.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_API_KEY=

# Sanctum: срок жизни токена в МИНУТАХ. Дефолт 7 дней (10080) — баланс
# между UX (партнёр не релогинится каждый день) и безопасностью.
# Можно увеличить до 30 дней (43200), но не больше.
SANCTUM_TOKEN_EXPIRATION=10080

# Insmart — приём webhook'ов о платежах + push в их API.
# Webhook secret используется для проверки HMAC SHA256 подписи входящих,
# рекомендуется длина ≥ 32 символов (openssl rand -hex 32).
INSMART_API_BASE_URL=https://api.insmart.ru/v1
INSMART_API_KEY=
INSMART_WEBHOOK_SECRET=

# Telegram — алерты health-check + сообщения собственику.
# Токен — от @BotFather. chat_id можно узнать через @userinfobot или
# `getUpdates` после первого сообщения боту.
TELEGRAM_BOT_TOKEN=
TELEGRAM_STATUS_CHAT_ID=

# Zammad helpdesk (опционально, если используешь интеграцию).
ZAMMAD_BASE_URL=
ZAMMAD_TOKEN=
ZAMMAD_WEBHOOK_SECRET=
